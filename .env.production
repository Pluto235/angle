# 模板文件：部署前复制为 .env 再运行 docker compose / deploy.sh
# 实际运行统一读取 .env，不直接读取本文件
POSTGRES_DB="angle"
POSTGRES_USER="angle"
POSTGRES_PASSWORD="angle"
DATABASE_URL="postgresql://angle:angle@db:5432/angle?schema=public"
AUTH_SECRET="change-me-in-production"
COOKIE_SECURE="false"
NEXT_TELEMETRY_DISABLED="1"
HOSTNAME="0.0.0.0"
PORT="3000"
RUN_DB_PUSH="true"
